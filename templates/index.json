    "collapsible_content_6jxHXe": {
      "type": "collapsible-content",
      "blocks": {
        "collapsible_row_aNCdVN": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How long does it take to receive my figurine?",
            "icon": "none",
            "row_content": "<p>Each figurine is handmade from start to finish, so production typically takes 2–3 weeks depending on complexity. We’ll send you progress photos before shipping to ensure everything looks perfect.</p>",
            "page": ""
          }
        },
        "collapsible_row_6Fy4LH": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Can I customize the pose, clothing, or accessories?",
            "icon": "none",
            "row_content": "<p>Yes! At Tarelcraft, we specialize in custom and personalized creations. You can share your ideas, text, or photos, and we’ll craft something unique just for you.</p>",
            "page": ""
          }
        },
        "collapsible_row_GxFFqm": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What materials are used to make the figurines?",
            "icon": "none",
            "row_content": "<p>We use high-quality, durable materials such as wood, resin, clay, and eco-friendly paints—depending on the product type.</p>",
            "page": ""
          }
        },
        "collapsible_row_TGfrT8": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Will I see a preview before my figurine ships?",
            "icon": "none",
            "row_content": "<p>Absolutely! We share a digital preview/mockup before production. You can approve it or request small changes if needed.<br/><br/></p>",
            "page": ""
          }
        },
        "collapsible_row_NRgbDn": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Do you ship internationally?",
            "icon": "none",
            "row_content": "<p>Yes, international orders may take 7–14 days.</p>",
            "page": ""
          }
        },
        "collapsible_row_YKr34C": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What if my figurine arrives damaged?",
            "icon": "none",
            "row_content": "<p>We're really sorry if that happens! Please contact us within 48 hours of delivery with photos of the issue, and we’ll arrange a replacement or refund as per our policy.</p>",
            "page": ""
          }
        },
        "collapsible_row_bfp4Uk": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Can I order multiple figurines for a group or event?",
            "icon": "none",
            "row_content": "",
            "page": ""
          }
        },
        "collapsible_row_yH9ztc": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Do you offer gift cards?",
            "icon": "none",
            "row_content": "<p>Absolutely! We offer gift cards that make the perfect gift. You can choose the amount, and the recipient can use it anytime on any of our offerings.</p>",
            "page": ""
          }
        }
      },
