}

.timer {
  display: flex;
  justify-content: center;
  gap: 15px;
}

.timer div {
  background: #2a2a40;
  padding: 5px;
  border-radius: 8px;
  min-width: 60px;
}

.timer span {
  font-size: 22px;
  line-height: 1.4;
  font-weight: bold;
  display: block;
}

.timer small {
  font-size: 10px;
  opacity: 0.7;
}
