<script defer>

document.addEventListener("DOMContentLoaded", function () {

  const optionRows = document.querySelectorAll(".custom_options_row");

  optionRows.forEach(function (row) {

    const radios = row.querySelectorAll("input[type='radio']");
    const valueSpan = row.querySelector(".custom_js_value");
   

    radios.forEach(function (radio) {
      radio.addEventListener("change", function () {
        if (this.checked && valueSpan) {
          valueSpan.textContent = this.value;
        }
      });
    });

    const checked = row.querySelector("input[type='radio']:checked");
    if (checked && valueSpan) {
      valueSpan.textContent = checked.value;
    }

  });

});

function replaceImgWithSvg(imgElement) {
    const imgURL = imgElement.getAttribute("src");

    fetch(imgURL)
        .then(response => response.text())
        .then(svgText => {
            const parser = new DOMParser();
            const svgDoc = parser.parseFromString(svgText, "image/svg+xml");
            const svgElement = svgDoc.querySelector("svg");

            if (!svgElement) return;

            // Copy classes and attributes from <img> to <svg>
            if (imgElement.id) svgElement.id = imgElement.id;
            if (imgElement.className) svgElement.classList = imgElement.classList;

            // Replace the <img> with the <svg>
            imgElement.replaceWith(svgElement);
        })
        .catch(error => console.error("SVG fetch error:", error));
}
document.querySelectorAll(".has-icon-option img").forEach(img => replaceImgWithSvg(img));
</script>
<script defer>
document.addEventListener("DOMContentLoaded", function () {

  const allFileInputs = document.querySelectorAll(".images_changer input[type='file']");

  allFileInputs.forEach((input) => {

    input.addEventListener("change", function () {
      const file = this.files[0];
      if (!file) return;

      const label = document.querySelector(`label[for="${this.id}"]`);
      const img = label.querySelector("img");

      const reader = new FileReader();

      reader.onload = function (e) {

        // save default image once
        if (!img.dataset.default) {
          img.dataset.default = img.src;
        }

        // replace image
        img.src = e.target.result;

        // remove old cross if exists
        const oldBtn = label.querySelector(".remove-image");
        if (oldBtn) oldBtn.remove();

        // create cross button
        const removeBtn = document.createElement("span");
        removeBtn.innerHTML = "✖";
        removeBtn.classList.add("remove-image");

        // styling
        label.style.position = "relative";
        Object.assign(removeBtn.style, {
          position: "absolute",
          top: "5px",
          right: "5px",
          background: "#000",
          color: "#fff",
          width: "18px",
          height: "18px",
          display: "flex",
          alignItems: "center",
          justifyContent: "center",
          borderRadius: "50%",
          cursor: "pointer",
          fontSize: "12px"
        });

        label.appendChild(removeBtn);

        // remove logic
        removeBtn.addEventListener("click", function (ev) {
          ev.preventDefault();
          ev.stopPropagation();

          img.src = img.dataset.default; // reset
          input.value = ""; // clear input
          removeBtn.remove();
        });

      };

      reader.readAsDataURL(file);
    });

  });

});
</script>


