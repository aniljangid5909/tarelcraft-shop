{%- comment -%}
  ABOUT SECTION – Inspired by provided screenshot
{%- endcomment -%}
 {%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<style>
    about-wrapper {
  padding: 60px 0;
}

.about-inner {
  display: flex;
  flex-wrap: wrap;
  gap: 40px;
  max-width: 900px;
}

.about-left,
.about-right {
  flex: 1 1 350px;
}

.founder-photo {
  margin: 0 0 24px;
  text-align: center;
}

.founder-photo img {
  width: 100%;
  max-width: 100%;
  border-radius: 8px;
  object-fit: cover;
}

.founder-title {
  margin-top: 8px;
  font-weight: 600;
  font-size: 2.4rem;
}

.about-highlights .highlight {
  display: flex;
  gap: 16px;
  margin-bottom: 24px;
}

.highlight-icon {
  flex-shrink: 0;
  width: 48px;
  height: auto;
  object-fit: contain;
}

.highlight-heading {
  margin: 0 0 4px;
  font-size: 1.8rem;
  font-weight: 700;
}

.highlight-body {
  margin: 0;
  font-size: 1.4rem;
  line-height: 1.45;
}

.about-heading {
  font-size: 3.2rem;
  font-weight: 700;
  margin-top: 0px;
  margin-bottom: 20px;
}

.about-story {
  font-size: 1.4rem;
  line-height: 1.2;
}
</style>
<section class="about-wrapper color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="about-inner page-width">

    <!--⁠–– Left column – Founder, mission, touch –––-->
    <div class="about-left">
      {% if section.settings.founder_image != blank %}
        <figure class="founder-photo">
          <img
            src="{{ section.settings.founder_image | image_url: width: 600 }}"
            alt="{{ section.settings.founder_title | escape }}"
            width="100%"
            height="auto">
          {% if section.settings.founder_title != blank %}
            <figcaption class="founder-title">{{ section.settings.founder_title }}</figcaption>
          {% endif %}
        </figure>
      {% endif %}

      <div class="about-highlights">

        <div class="highlight">
          {% if section.settings.mission_icon != blank %}
            <img src="{{ section.settings.mission_icon | image_url: width: 48 }}"
                 alt="{{ section.settings.mission_heading | escape }}"
                 class="highlight-icon">
          {% endif %}
          <div class="highlight-text">
            <h3 class="highlight-heading">{{ section.settings.mission_heading }}</h3>
            <p class="highlight-body">{{ section.settings.mission_text }}</p>
          </div>
        </div>

        <div class="highlight">
          {% if section.settings.touch_icon != blank %}
            <img src="{{ section.settings.touch_icon | image_url: width: 48 }}"
                 alt="{{ section.settings.touch_heading | escape }}"
                 class="highlight-icon">
          {% endif %}
          <div class="highlight-text">
            <h3 class="highlight-heading">{{ section.settings.touch_heading }}</h3>
            <p class="highlight-body">{{ section.settings.touch_text }}</p>
          </div>
        </div>

      </div>
    </div>

    <!--⁠–– Right column – Story –––-->
    <div class="about-right">
      {% if section.settings.heading != blank %}
        <h2 class="about-heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.story != blank %}
        <div class="about-story">{{ section.settings.story }}</div>
      {% endif %}
    </div>

  </div>

  <!--⁠–– Team strip –––-->
  {% if section.blocks.size > 0 %}
    <div class="team-strip page-width">
      {%- for block in section.blocks -%}
        {% if block.type == 'team_member' and block.settings.team_image != blank %}
          <div class="team-member" {{ block.shopify_attributes }}>
            <img
              src="{{ block.settings.team_image | image_url: width: 500 }}"
              alt="Team member {{ forloop.index }}"
              width="100%"
              height="auto">
          </div>
        {% endif %}
      {%- endfor -%}
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "About – Founder & Team",
  "tag": "section",
  "class": "section-about",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Why Tarelcraft was founded"
    },
    {
      "type": "image_picker",
      "id": "founder_image",
      "label": "Founder photo"
    },
    {
      "type": "text",
      "id": "founder_title",
      "label": "Founder title",
      "default": "Founder"
    },
    {
      "type": "richtext",
      "id": "story",
      "label": "Story text",
      "default": "<p>I founded TARELCRAFT because ...</p>"
    },
    {
      "type": "image_picker",
      "id": "mission_icon",
      "label": "Mission icon"
    },
    {
      "type": "text",
      "id": "mission_heading",
      "label": "Mission heading",
      "default": "Mission"
    },
    {
      "type": "text",
      "id": "mission_text",
      "label": "Mission description",
      "default": "Unforgettable gifts for people worldwide"
    },
    {
      "type": "image_picker",
      "id": "touch_icon",
      "label": "Personal touch icon"
    },
    {
      "type": "text",
      "id": "touch_heading",
      "label": "Personal touch heading",
      "default": "Personal Touch"
    },
    {
      "type": "text",
      "id": "touch_text",
      "label": "Personal touch description",
      "default": "Every figurine tells a story"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "team_member",
      "name": "Team member",
      "settings": [
        {
          "type": "image_picker",
          "id": "team_image",
          "label": "Team photo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About – Founder & Team"
    }
  ]
}
{% endschema %}
