
{% assign amoni_section_id = section.id | replace: '_', ''| replace:"-","" | downcase %}

{% style %}

  .section-video-slider-{{ amoni_section_id }} {
    width: 100%;
    padding: {{ section.settings.section_padding_top }}px 0 {{ section.settings.section_padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
    display: block;
  }
  .section-video-slider-{{ amoni_section_id }} h2,
  .section-video-slider-{{ amoni_section_id }} h2 p{
    margin:0;
    margin-bottom:20px;
  }
  .section-video-slider-contsectionner-{{ amoni_section_id }} {
    max-width: {{ section.settings.contsectionner_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .section-video-slider-header-{{ amoni_section_id }} {
    text-align: {{ section.settings.text_alignment }};
    margin-bottom: 40px;
  }

  .section-video-slider-heading-{{ amoni_section_id }} {
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_size }}px;
    margin: 0 0 16px;
  }

  .section-video-slider-subheading-{{ amoni_section_id }} {
    color: {{ section.settings.subheading_color }};
    font-size: {{ section.settings.subheading_size }}px;
    margin: 0;
  }

  .section-video-slider-wrapper-{{ amoni_section_id }} {
    position: relative;
    overflow: hidden;
  }

  .section-video-slider-track-{{ amoni_section_id }} {
    display: flex;
    gap: {{ section.settings.slide_gap }}px;
    transition: transform 0.5s ease;
  }

  .section-video-slider-slide-{{ amoni_section_id }} {
    flex: 0 0 calc((100% - ({{ section.settings.slides_per_view | minus: 1 }} * {{ section.settings.slide_gap }}px)) / {{ section.settings.slides_per_view }});
    position: relative;
    border-radius: {{ section.settings.video_border_radius }}px;
    overflow: hidden;
  }

  .section-video-slider-video-wrapper-{{ amoni_section_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ section.settings.video_aspect_ratio }}%;
    background-color: #000;
    border-radius: {{ section.settings.video_border_radius }}px;
    overflow: hidden;
  }

  .section-video-slider-video-{{ amoni_section_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .section-video-slider-placeholder-{{ amoni_section_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .section-video-slider-placeholder-{{ amoni_section_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .section-video-play-pause-{{ amoni_section_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: {{ section.settings.play_button_size }}px;
    height: {{ section.settings.play_button_size }}px;
    border-radius: 50%;
    background-color: {{ section.settings.play_button_bg_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    opacity: 0.9;
    z-index: 2;
  }

  .section-video-play-pause-{{ amoni_section_id }}:hover {
    background-color: {{ section.settings.play_button_hover_bg_color }};
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.1);
  }

  .section-video-play-pause-{{ amoni_section_id }} svg {
    width: calc({{ section.settings.play_button_size }}px * 0.4);
    height: calc({{ section.settings.play_button_size }}px * 0.4);
    fill: {{ section.settings.play_button_icon_color }};
  }

  .section-video-play-pause-{{ amoni_section_id }}.playing {
    opacity: 0;
  }

  .section-video-slider-video-wrapper-{{ amoni_section_id }}:hover .section-video-play-pause-{{ amoni_section_id }}.playing {
    opacity: 0.7;
  }

  .section-video-slider-caption-{{ amoni_section_id }} {
    margin-top: 12px;
    color: {{ section.settings.caption_color }};
    font-size: {{ section.settings.caption_size }}px;
    text-align: {{ section.settings.text_alignment }};
  }

  .section-video-slider-controls-{{ amoni_section_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: 30px;
  }

  .section-video-slider-nav-{{ amoni_section_id }} {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background-color: {{ section.settings.nav_button_color }};
    color: {{ section.settings.nav_button_icon_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
  }

  .section-video-slider-nav-{{ amoni_section_id }}:hover {
    background-color: {{ section.settings.nav_button_hover_color }};
  }

  .section-video-slider-nav-{{ amoni_section_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .section-video-slider-dots-{{ amoni_section_id }} {
    display: flex;
    gap: 10px;
  }

  .section-video-slider-dot-{{ amoni_section_id }} {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: {{ section.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.3s ease;
    padding: 0;
  }

  .section-video-slider-dot-{{ amoni_section_id }}.active {
    background-color: {{ section.settings.dot_active_color }};
    transform: scale(1.3);
  }

  @media screen and (max-width: 989px) {
    .section-video-slider-slide-{{ amoni_section_id }} {
      flex: 0 0 calc((100% - ({{ section.settings.slides_per_view_tablet | minus: 1 }} * {{ section.settings.slide_gap }}px)) / {{ section.settings.slides_per_view_tablet }});
    }

    .section-video-slider-heading-{{ amoni_section_id }} {
      font-size: calc({{ section.settings.heading_size }}px * 0.8);
    }

    .section-video-slider-subheading-{{ amoni_section_id }} {
      font-size: calc({{ section.settings.subheading_size }}px * 0.9);
    }

    .section-video-play-pause-{{ amoni_section_id }} {
      width: calc({{ section.settings.play_button_size }}px * 0.8);
      height: calc({{ section.settings.play_button_size }}px * 0.8);
    }

    .section-video-play-pause-{{ amoni_section_id }} svg {
      width: calc({{ section.settings.play_button_size }}px * 0.32);
      height: calc({{ section.settings.play_button_size }}px * 0.32);
    }
  }

  @media screen and (max-width: 749px) {
    .section-video-slider-slide-{{ amoni_section_id }} {
      flex: 0 0 100%;
    }

    .section-video-slider-heading-{{ amoni_section_id }} {
      font-size: calc({{ section.settings.heading_size }}px * 0.7);
    }

    .section-video-slider-subheading-{{ amoni_section_id }} {
      font-size: calc({{ section.settings.subheading_size }}px * 0.8);
    }

    .section-video-slider-nav-{{ amoni_section_id }} {
      width: 40px;
      height: 40px;
    }

    .section-video-play-pause-{{ amoni_section_id }} {
      width: calc({{ section.settings.play_button_size }}px * 0.7);
      height: calc({{ section.settings.play_button_size }}px * 0.7);
    }

    .section-video-play-pause-{{ amoni_section_id }} svg {
      width: calc({{ section.settings.play_button_size }}px * 0.28);
      height: calc({{ section.settings.play_button_size }}px * 0.28);
    }
  }
{% endstyle %}

<video-slider-{{ amoni_section_id }} class="section-video-slider-{{ amoni_section_id }} color-{{ section.settings.color_scheme }}" {{ section.shopify_attributes }}>
  <div class="section-video-slider-contsectionner-{{ amoni_section_id }}">
    {% if section.settings.heading != blank or section.settings.subheading != blank %}
      <div class="section-video-slider-header-{{ amoni_section_id }}">
        {% if section.settings.heading != blank %}
          <h2 class="section-video-slider-heading-{{ amoni_section_id }}">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <div class="section-video-slider-subheading-{{ amoni_section_id }}">{{ section.settings.subheading }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="section-video-slider-wrapper-{{ amoni_section_id }}">
      <div class="section-video-slider-track-{{ amoni_section_id }}" data-track>
        {% for i in (1..6) %}
          {% liquid
            assign video_key = 'video_' | append: i
            assign caption_key = 'caption_' | append: i
            assign video = section.settings[video_key]
            assign caption = section.settings[caption_key]
          %}
{% if video != blank %}
          <div class="section-video-slider-slide-{{ amoni_section_id }}">
            <div class="section-video-slider-video-wrapper-{{ amoni_section_id }}">
              
                <video
                  class="section-video-slider-video-{{ amoni_section_id }}"
                  {% if section.settings.loop %}loop{% endif %}
                  {% if section.settings.muted %}muted{% endif %}
                  {% if section.settings.controls %}controls{% endif %}
                  playsinline
                  data-video
                >
                  <source src="{{ video }}" type="video/mp4">
                </video>
                <button
                  class="section-video-play-pause-{{ amoni_section_id }}"
                  aria-label="Play video"
                  data-play-pause
                >
                  <svg class="play-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                  <svg class="pause-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="display: none;">
                    <path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/>
                  </svg>
                </button>
                {% comment %} 
                  <div class="section-video-slider-placeholder-{{ amoni_section_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div> 
                {% endcomment %}                
            </div>
            {% if caption != blank %}
              <div class="section-video-slider-caption-{{ amoni_section_id }}">{{ caption }}</div>
            {% endif %}
          </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    {% if section.settings.show_controls %}
      <div class="section-video-slider-controls-{{ amoni_section_id }}">
        <button
          class="section-video-slider-nav-{{ amoni_section_id }} section-video-slider-prev-{{ amoni_section_id }}"
          aria-label="Previous slide"
          data-prev
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>

        {% if section.settings.show_dots %}
          <div class="section-video-slider-dots-{{ amoni_section_id }}" data-dots></div>
        {% endif %}

        <button
          class="section-video-slider-nav-{{ amoni_section_id }} section-video-slider-next-{{ amoni_section_id }}"
          aria-label="Next slide"
          data-next
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    {% endif %}
  </div>
</video-slider-{{ amoni_section_id }}>

<script>
  (function() {
    class VideoSlider{{ amoni_section_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.slidesPerView = {{ section.settings.slides_per_view }};
        this.autoplayEnabled = {{ section.settings.enable_autoplay }};
        this.autoplayDelay = {{ section.settings.autoplay_delay }} * 1000;
        this.autoplayTimer = null;
      }

      connectedCallback() {
        this.track = this.querySelector('[data-track]');
        this.slides = this.track.querySelectorAll('.section-video-slider-slide-{{ amoni_section_id }}');
        this.prevButton = this.querySelector('[data-prev]');
        this.nextButton = this.querySelector('[data-next]');
        this.dotsContsectionner = this.querySelector('[data-dots]');

        this.updateSlidesPerView();
        this.setupEventListeners();
        this.setupVideoControls();
        this.createDots();
        this.updateSlider();

        if (this.autoplayEnabled) {
          this.startAutoplay();
        }

        window.addEventListener('resize', () => this.updateSlidesPerView());
      }

      setupVideoControls() {
        const videoWrappers = this.querySelectorAll('.section-video-slider-video-wrapper-{{ amoni_section_id }}');
        
        videoWrappers.forEach((wrapper) => {
          const video = wrapper.querySelector('[data-video]');
          const playPauseBtn = wrapper.querySelector('[data-play-pause]');
          
          if (!video || !playPauseBtn) return;

          const playIcon = playPauseBtn.querySelector('.play-icon');
          const pauseIcon = playPauseBtn.querySelector('.pause-icon');

          playPauseBtn.addEventListener('click', () => {
            if (video.paused) {
              video.play();
              playIcon.style.display = 'none';
              pauseIcon.style.display = 'block';
              pauseIcon.style.display = 'section';
              playPauseBtn.classList.add('playing');
              playPauseBtn.setAttribute('aria-label', 'Pause video');
            } else {
              video.pause();
              playIcon.style.display = 'section';
              playIcon.style.display = 'block';
              pauseIcon.style.display = 'none';
              playPauseBtn.classList.remove('playing');
              playPauseBtn.setAttribute('aria-label', 'Play video');
            }
          });

          video.addEventListener('ended', () => {
            playIcon.style.display = 'section';
            pauseIcon.style.display = 'none';
            playIcon.style.display = 'block';
            playPauseBtn.classList.remove('playing');
            playPauseBtn.setAttribute('aria-label', 'Play video');
          });

          video.addEventListener('click', () => {
            playPauseBtn.click();
          });
        });
      }

      updateSlidesPerView() {
        const width = window.innerWidth;
        if (width <= 749) {
          this.slidesPerView = 1;
        } else if (width <= 989) {
          this.slidesPerView = {{ section.settings.slides_per_view_tablet }};
        } else {
          this.slidesPerView = {{ section.settings.slides_per_view }};
        }
        this.updateSlider();
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => {
            this.goToPrev();
            this.resetAutoplay();
          });
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => {
            this.goToNext();
            this.resetAutoplay();
          });
        }

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => {
          if (this.autoplayEnabled) {
            this.startAutoplay();
          }
        });
      }

      createDots() {
        if (!this.dotsContsectionner) return;

        const totalSlides = this.slides.length;
        const totalDots = Math.ceil(totalSlides - this.slidesPerView + 1);

        this.dotsContsectionner.innerHTML = '';

        for (let i = 0; i < totalDots; i++) {
          const dot = document.createElement('button');
          dot.className = 'section-video-slider-dot-{{ amoni_section_id }}';
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          dot.addEventListener('click', () => {
            this.currentIndex = i;
            this.updateSlider();
            this.resetAutoplay();
          });
          this.dotsContsectionner.appendChild(dot);
        }
      }

      updateSlider() {
        const slideWidth = this.slides[0].offsetWidth;
        const gap = {{ section.settings.slide_gap }};
        const offset = -(this.currentIndex * (slideWidth + gap));

        this.track.style.transform = `translateX(${offset}px)`;

        if (this.prevButton) {
          this.prevButton.disabled = this.currentIndex === 0;
        }

        if (this.nextButton) {
          const maxIndex = this.slides.length - this.slidesPerView;
          this.nextButton.disabled = this.currentIndex >= maxIndex;
        }

        this.updateDots();
      }

      updateDots() {
        if (!this.dotsContsectionner) return;

        const dots = this.dotsContsectionner.querySelectorAll('.section-video-slider-dot-{{ amoni_section_id }}');
        dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      goToPrev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateSlider();
        }
      }

      goToNext() {
        const maxIndex = this.slides.length - this.slidesPerView;
        if (this.currentIndex < maxIndex) {
          this.currentIndex++;
          this.updateSlider();
        }
      }

      startAutoplay() {
        if (!this.autoplayEnabled) return;

        this.autoplayTimer = setInterval(() => {
          const maxIndex = this.slides.length - this.slidesPerView;
          if (this.currentIndex < maxIndex) {
            this.goToNext();
          } else {
            this.currentIndex = 0;
            this.updateSlider();
          }
        }, this.autoplayDelay);
      }

      stopAutoplay() {
        if (this.autoplayTimer) {
          clearInterval(this.autoplayTimer);
          this.autoplayTimer = null;
        }
      }

      resetAutoplay() {
        this.stopAutoplay();
        if (this.autoplayEnabled) {
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
        window.removeEventListener('resize', () => this.updateSlidesPerView());
      }
    }

    customElements.define('video-slider-{{ amoni_section_id }}', VideoSlider{{ amoni_section_id }});
  })();
</script>

{% schema %}
{
  "name": "Video slider",
  "tag": "section",
  "class":"video-section-slider",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Video Gallery</p>"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Explore our collection</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Videos"
    },
    {
      "type": "url",
      "id": "video_1",
      "label": "Video 1 URL"
    },
    {
      "type": "richtext",
      "id": "caption_1",
      "label": "Caption 1"
    },
    {
      "type": "url",
      "id": "video_2",
      "label": "Video 2 URL"
    },
    {
      "type": "richtext",
      "id": "caption_2",
      "label": "Caption 2"
    },
    {
      "type": "url",
      "id": "video_3",
      "label": "Video 3 URL"
    },
    {
      "type": "richtext",
      "id": "caption_3",
      "label": "Caption 3"
    },
    {
      "type": "url",
      "id": "video_4",
      "label": "Video 4 URL"
    },
    {
      "type": "richtext",
      "id": "caption_4",
      "label": "Caption 4"
    },
    {
      "type": "url",
      "id": "video_5",
      "label": "Video 5 URL"
    },
    {
      "type": "richtext",
      "id": "caption_5",
      "label": "Caption 5"
    },
    {
      "type": "url",
      "id": "video_6",
      "label": "Video 6 URL"
    },
    {
      "type": "richtext",
      "id": "caption_6",
      "label": "Caption 6"
    },
    {
      "type": "header",
      "content": "Video settings"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop videos",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "muted",
      "label": "Mute videos",
      "default": true
    },
    {
      "type": "checkbox",
