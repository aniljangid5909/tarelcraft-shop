      "max": 1600,
      "step": 100,
      "unit": "px",
      "label": "Contsectionner width",
      "default": 1400
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 50
    },
